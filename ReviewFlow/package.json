{
  "name": "reviewflow",
  "version": "0.1.0",
  "private": true,
  "description": "Business dataflow review tool prototype with a Node, Express, Prisma sample backend.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/src/server.js",
    "analyze:order": "tsx src/analyzer/staticAnalyzer.ts",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "express": "^4.21.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
